# Admin Panel Configuration
# Copy this to .env and fill in your values

# JWT secret for admin sessions (use a long random string in production!)
JWT_SECRET=change-me-in-production-min-32chars!!

# Default admin credentials (created on first startup if no users exist)
ADMIN_EMAIL=admin@dh-agentur.de
ADMIN_PASSWORD=changeme123

# Public site URL (used in OpenRouter API referrer header)
NUXT_PUBLIC_SITE_URL=https://dh-agentur.de
