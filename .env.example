# ─────────────────────────────────────────────────────────────────────────────
# DH Agentur — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Admin authentication ──────────────────────────────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production-min-32chars!!
ADMIN_EMAIL=admin@dh-agentur.de
ADMIN_PASSWORD=changeme

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public-facing URL of the frontend (used for canonical links, og:url, etc.)
FRONTEND_URL=https://dh-agentur.de

# Public-facing URL of the backend (admin + API).
# The frontend uses this to fetch content via /api/public/*.
BACKEND_URL=https://admin.dh-agentur.de

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin(s) the backend allows for /api/public/* requests.
# Set to your frontend domain in production (e.g. https://dh-agentur.de).
# Defaults to * (all origins) if not set — fine for read-only public API.
# FRONTEND_URL is reused for this; override separately if needed.

# ── OpenRouter (AI generator) ────────────────────────────────────────────────
# Set in the admin panel UI — no env var needed.

# ── Internal Docker network ───────────────────────────────────────────────────
# When both containers run on the same Docker host, the frontend can reach
# the backend via the internal service name instead of the public domain:
#   NUXT_PUBLIC_BACKEND_URL=http://backend:3001
# This is already the default in docker-compose.yml.
